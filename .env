# Настройки базы данных
DJANGO_DB_HOST=db
DJANGO_DB_NAME=netassets_db
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=yourpassword

# (Если нужно) Секретный ключ Django
# DJANGO_SECRET_KEY=your-secret-key

# (Если используется LDAP, добавьте при необходимости)
# AUTH_LDAP_SERVER_URI=ldap://ad.example.com
# AUTH_LDAP_BIND_DN=CN=ldap_user,CN=Users,DC=example,DC=com
# AUTH_LDAP_BIND_PASSWORD=your_ldap_password